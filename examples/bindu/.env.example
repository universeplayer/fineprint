# Required: API key for the LLM used to analyse the contract.
# OpenRouter gives you access to Claude, GPT-4o, Gemini, DeepSeek, and many
# more behind a single key — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional: override the model (default: anthropic/claude-sonnet-4)
# CONTRACTGUARD_MODEL=openai/gpt-4o

# Optional: analysis language (en | zh). Default: en.
# CONTRACTGUARD_LANG=en

# Optional: identity that signs the agent's DID document. Use a real email
# you control if you plan to expose this agent publicly.
# CONTRACTGUARD_AUTHOR=you@example.com
